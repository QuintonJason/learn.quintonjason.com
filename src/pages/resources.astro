---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources | Learn Web Design With Quinton Jason">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Resources</p>
        <h1>Reference material for better web work.</h1>
        <p class="lede">
          A living collection of tools, references, checklists, and reading that
          supports the course.
        </p>
      </div>
      <div class="resource-grid">
        <article class="resource-card">
          <h2>HTML References</h2>
          <p>Semantic elements, document structure, links, forms, and media.</p>
        </article>
        <article class="resource-card">
          <h2>CSS References</h2>
          <p>The cascade, custom properties, typography, layout, and responsive design.</p>
        </article>
        <article class="resource-card">
          <h2>Accessibility Checks</h2>
          <p>Keyboard testing, labels, focus, contrast, headings, and screen reader basics.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
