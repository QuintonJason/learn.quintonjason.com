---
import '../styles/global.css';

const {
  title = 'Learn Web Design With Quinton Jason',
  description = 'A practical guide to HTML, CSS, accessibility, responsive design, UX foundations, and systems thinking.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="site-brand" href="/" aria-label="Learn Web Design home">
          <span class="site-brand__mark">QJ</span>
          <span>Learn</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/lessons/">Lessons</a>
          <a href="/projects/">Projects</a>
          <a href="/resources/">Resources</a>
          <a href="https://quintonjason.com/">Portfolio</a>
        </nav>
      </div>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <p>Learn Web Design With Quinton Jason</p>
        <p>HTML, CSS, accessibility, responsive design, UX, and systems thinking.</p>
      </div>
    </footer>
  </body>
</html>
