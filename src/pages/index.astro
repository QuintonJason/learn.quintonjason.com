---
import BaseLayout from '../layouts/BaseLayout.astro';
import { lessons } from '../data/lessons';

const startPath = [
  {
    title: 'Set up your tools',
    lesson: lessons.find((lesson) => lesson.slug === 'developer-environment-setup'),
  },
  {
    title: 'Plan the website',
    lesson: lessons.find((lesson) => lesson.slug === 'website-process'),
  },
  {
    title: 'Learn HTML structure',
    lesson: lessons.find((lesson) => lesson.slug === 'basic-html-structure-and-elements'),
  },
  {
    title: 'Add CSS',
    lesson: lessons.find((lesson) => lesson.slug === 'intro-to-css'),
  },
  {
    title: 'Build layouts',
    lesson: lessons.find((lesson) => lesson.slug === 'flexbox'),
  },
  {
    title: 'Make it responsive',
    lesson: lessons.find((lesson) => lesson.slug === 'responsive-web-design'),
  },
  {
    title: 'Add interaction',
    lesson: lessons.find((lesson) => lesson.slug === 'javascript-in-the-dom'),
  },
  {
    title: 'Test accessibility',
    lesson: lessons.find((lesson) => lesson.slug === 'web-accessibility'),
  },
].filter((item) => item.lesson);

const helpPaths = [
  {
    title: 'Publishing your site',
    description: 'Use this when GitHub Pages, commits, or live URLs are the blocker.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'developer-environment-setup'),
      lessons.find((lesson) => lesson.slug === 'file-paths-and-site-structure'),
    ],
  },
  {
    title: 'Fixing broken images or links',
    description: 'Start here when something works locally but disappears after publishing.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'file-paths-and-site-structure'),
      lessons.find((lesson) => lesson.slug === 'image-optimization'),
    ],
  },
  {
    title: 'Cleaning up layout',
    description: 'Use this path when spacing, boxes, alignment, or responsiveness feels off.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'box-model-and-layout'),
      lessons.find((lesson) => lesson.slug === 'flexbox'),
      lessons.find((lesson) => lesson.slug === 'responsive-web-design'),
    ],
  },
  {
    title: 'Adding interaction',
    description: 'Use this when buttons, menus, or dynamic page behavior need to work.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'javascript-in-the-dom'),
      lessons.find((lesson) => lesson.slug === 'building-effective-site-navigation'),
    ],
  },
  {
    title: 'Fixing carousel behavior',
    description: 'Use this when slides all show, buttons do nothing, or autoplay gets messy.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'javascript-in-the-dom'),
      lessons.find((lesson) => lesson.slug === 'mastering-carousels'),
    ],
  },
  {
    title: 'Checking accessibility',
    description: 'Use this before final submission or any time a UI feels hard to use.',
    lessons: [
      lessons.find((lesson) => lesson.slug === 'html-forms-building-interactive-user-interfaces'),
      lessons.find((lesson) => lesson.slug === 'building-effective-site-navigation'),
      lessons.find((lesson) => lesson.slug === 'web-accessibility'),
    ],
  },
].map((path) => ({
  ...path,
  lessons: path.lessons.filter(Boolean),
}));
---

<BaseLayout>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <p class="eyebrow">ART 3020 Course Guide</p>
        <h1>ART 3020 Web Design.</h1>
        <p class="lede">
          A web version of the class book for developer environment setup,
          website process, HTML, CSS, JavaScript, animation, image optimization,
          templates, navigation, and carousels.
        </p>
        <div class="button-row">
          <a class="button button--primary" href="/lessons/">Start Learning</a>
          <a class="button" href="/projects/">View Projects</a>
        </div>
      </div>
      <aside class="hero-card" aria-label="Course focus">
        <h2>What this course teaches</h2>
        <ol>
          <li>Set up and publish class websites with GitHub Pages.</li>
          <li>Plan websites around audience, goals, content, and structure.</li>
          <li>Build pages with HTML, CSS, JavaScript, and media.</li>
          <li>Add motion, navigation, templates, and interaction responsibly.</li>
        </ol>
      </aside>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Start Here</p>
        <h2>A guided path through the first pass.</h2>
        <p>
          Use this sequence when you are starting the course, catching up, or
          reviewing the foundation before a project.
        </p>
      </div>

      <ol class="path-list">
        {
          startPath.map((item) => (
            <li>
              <a href={`/lessons/${item.lesson.slug}/`}>
                <span>Lesson {item.lesson.number}</span>
                <strong>{item.title}</strong>
                <small>{item.lesson.title}</small>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Need Help With...</p>
        <h2>Jump to the lessons that match the problem.</h2>
        <p>
          Use these paths when you are stuck in the middle of a project and do
          not need to move through the full course sequence.
        </p>
      </div>

      <div class="help-path-grid">
        {
          helpPaths.map((path) => (
            <article class="help-path-card">
              <h3>{path.title}</h3>
              <p>{path.description}</p>
              <ol>
                {
                  path.lessons.map((lesson) => (
                    <li>
                      <a href={`/lessons/${lesson.slug}/`}>
                        Lesson {lesson.number}: {lesson.title}
                      </a>
                    </li>
                  ))
                }
              </ol>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Lessons</p>
        <h2>The class sequence, adapted from the ART 3020 book.</h2>
        <p>
          These lessons follow the actual course material from setup through
          carousels.
        </p>
      </div>
      <div class="lesson-grid">
        {
          lessons.slice(0, 6).map((lesson) => (
            <a class="lesson-card" href={`/lessons/${lesson.slug}/`}>
              <span class="lesson-card__number">
                Lesson {lesson.number} / {lesson.eyebrow}
              </span>
              <h3>{lesson.title}</h3>
              <p>{lesson.summary}</p>
              <span class="lesson-card__footer">Open lesson</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="callout">
        <div>
          <p class="eyebrow">Teaching Philosophy</p>
          <h2>The class is the class.</h2>
        </div>
        <p>
          The goal of this site is to make the existing class book easier to
          navigate, read, and update on the web while preserving the course
          sequence, assignments, and practical classroom focus.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
