---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | Learn Web Design With Quinton Jason">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Projects</p>
        <h1>Practice through making.</h1>
        <p class="lede">
          Projects should help students connect structure, style, accessibility,
          responsiveness, and critique.
        </p>
      </div>
      <div class="resource-grid">
        <article class="resource-card">
          <h2>Semantic Profile</h2>
          <p>
            Build a personal profile page with semantic HTML, accessible links,
            images, and clear document structure.
          </p>
        </article>
        <article class="resource-card">
          <h2>Responsive Editorial Page</h2>
          <p>
            Design and code a long-form article page that adapts across screen
            sizes while preserving hierarchy and readability.
          </p>
        </article>
        <article class="resource-card">
          <h2>Interface System</h2>
          <p>
            Create a small set of reusable UI patterns with custom properties,
            layout rules, and accessibility notes.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
