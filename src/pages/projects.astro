---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Class Projects | Learn Web Design With Quinton Jason"
  description="ART 3020 project briefs, starter files, rubrics, examples, milestones, requirements, and supporting lessons for web design course assignments."
>
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Projects</p>
        <h1>Class projects and briefs.</h1>
        <p class="lede">
          The four major ART 3020 projects, organized with requirements,
          deliverables, grading criteria, and supporting lessons.
        </p>
      </div>
      <div class="project-list">
        {
          projects.map((project) => (
            <article class="project-card">
              <p class="project-card__meta">Project {project.number}</p>
              <h2>{project.shortTitle}</h2>
              <p>{project.summary}</p>
              <ul>
                {project.requirements.slice(0, 3).map((requirement) => <li>{requirement.title}</li>)}
              </ul>
              <div class="project-card__links">
                <a href={`/projects/${project.slug}/`}>View project brief</a>
                <a href={project.starterKit.files[0].href}>Open starter kit</a>
                {project.supportingLessons.slice(0, 3).map((lesson) => (
                  <a href={lesson.href}>{lesson.title}</a>
                ))}
              </div>
            </article>
          ))
        }
      </div>

      <section class="project-examples-overview" aria-labelledby="examples-title">
        <div class="section-heading">
          <p class="eyebrow">Examples Library</p>
          <h2 id="examples-title">See what strong, acceptable, and unfinished work can look like.</h2>
          <p>
            These are low-fidelity models for calibration. They show structure,
            decisions, and common issues without turning into templates to copy.
          </p>
        </div>
        <div class="mini-card-grid">
          {
            projects.filter((project) => project.models).map((project) => (
              <a class="mini-card" href={`/projects/${project.slug}/#example-models`}>
                <span>Project {project.number}</span>
                <strong>{project.shortTitle}</strong>
                <small>{project.models?.length ?? 0} example models</small>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
