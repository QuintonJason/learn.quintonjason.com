---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects | Learn Web Design With Quinton Jason">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Projects</p>
        <h1>Class projects and briefs.</h1>
        <p class="lede">
          The four major ART 3020 projects, organized with requirements,
          deliverables, grading criteria, and supporting lessons.
        </p>
      </div>
      <div class="project-list">
        {
          projects.map((project) => (
            <article class="project-card">
              <p class="project-card__meta">Project {project.number}</p>
              <h2>{project.shortTitle}</h2>
              <p>{project.summary}</p>
              <ul>
                {project.requirements.slice(0, 3).map((requirement) => <li>{requirement.title}</li>)}
              </ul>
              <div class="project-card__links">
                <a href={`/projects/${project.slug}/`}>View project brief</a>
                {project.supportingLessons.slice(0, 3).map((lesson) => (
                  <a href={lesson.href}>{lesson.title}</a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
