---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | Learn Web Design With Quinton Jason">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Projects</p>
        <h1>Class projects and exercises.</h1>
        <p class="lede">
          Practice work pulled from the ART 3020 class flow: setup, pages,
          styling, layout, interaction, animation, media, and navigation.
        </p>
      </div>
      <div class="resource-grid">
        <article class="resource-card">
          <h2>Simple Page</h2>
          <p>
            Create a basic HTML page with headings, paragraphs, images, lists,
            and links.
          </p>
        </article>
        <article class="resource-card">
          <h2>About Me and Contact Pages</h2>
          <p>
            Build linked internal pages that practice file paths, content
            structure, email links, and telephone links.
          </p>
        </article>
        <article class="resource-card">
          <h2>Motion and Navigation Demos</h2>
          <p>
            Practice transforms, transitions, animations, GSAP timelines,
            responsive navigation, and carousel behavior.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
