---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AccessibilityCheckLab from '../../components/AccessibilityCheckLab.astro';
import AnimationKeyframeLab from '../../components/AnimationKeyframeLab.astro';
import BoxModelVisualizer from '../../components/BoxModelVisualizer.astro';
import CarouselAccessibilityLab from '../../components/CarouselAccessibilityLab.astro';
import DomInteractionLab from '../../components/DomInteractionLab.astro';
import FilePathLab from '../../components/FilePathLab.astro';
import FlexboxPlayground from '../../components/FlexboxPlayground.astro';
import FontPairingLab from '../../components/FontPairingLab.astro';
import FormAccessibilityLab from '../../components/FormAccessibilityLab.astro';
import GsapTimelineLab from '../../components/GsapTimelineLab.astro';
import ImageOptimizationLab from '../../components/ImageOptimizationLab.astro';
import NavigationPatternLab from '../../components/NavigationPatternLab.astro';
import PageTemplateLab from '../../components/PageTemplateLab.astro';
import PositioningLab from '../../components/PositioningLab.astro';
import ResponsiveLayoutVisualizer from '../../components/ResponsiveLayoutVisualizer.astro';
import SelectorPlayground from '../../components/SelectorPlayground.astro';
import TransitionPlayground from '../../components/TransitionPlayground.astro';
import TransformLab from '../../components/TransformLab.astro';
import { getDemoGuidance, getDemoSourceUrl, getLessonCheckpoint, getLessonMeta, getTeacherNotes, isInteractiveLesson } from '../../data/lessonMeta';
import { lessons } from '../../data/lessons';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return lessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const currentIndex = lessons.findIndex((item) => item.slug === lesson.slug);
const previousLesson = lessons[currentIndex - 1];
const nextLesson = lessons[currentIndex + 1];
const hasInteractiveDemo = isInteractiveLesson(lesson);
const demoSourceUrl = getDemoSourceUrl(lesson);
const demoGuidance = getDemoGuidance(lesson);
const lessonMeta = getLessonMeta(lesson, currentIndex);
const lessonCheckpoint = getLessonCheckpoint(lesson);
const teacherNotes = getTeacherNotes(lesson);
const supportingProjects = projects.filter((project) =>
  project.supportingLessons.some((supportingLesson) => supportingLesson.href === `/lessons/${lesson.slug}/`)
);
const isExternalHref = (href: string) => href.startsWith('http://') || href.startsWith('https://');
const escapeHtml = (value: string) =>
  value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
const renderInlineLinks = (value: string) =>
  escapeHtml(value).replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+|\/[^)\s]*)\)/g, (_match, label, href) => {
    const isExternal = href.startsWith('http://') || href.startsWith('https://');
    const target = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';

    return `<a href="${href}"${target}>${label}</a>`;
  });
const pageSections = [
  { href: '#learning-goals', label: 'Learning Goals' },
  ...(hasInteractiveDemo ? [{ href: '#interactive-demo', label: 'Interactive Demo' }] : []),
  { href: '#lesson-content', label: 'Lesson Content' },
  { href: '#checkpoint', label: 'Checkpoint' },
  ...(supportingProjects.length ? [{ href: '#supports-projects', label: 'Supports Projects' }] : []),
  ...(lesson.practice ? [{ href: '#practice', label: 'Practice' }] : []),
  ...(lesson.resources ? [{ href: '#resources', label: 'Resources' }] : []),
];
---

<BaseLayout
  title={`${lesson.title} | Learn Web Design With Quinton Jason`}
  description={lesson.summary}
  type="article"
>
  <article class="lesson-page">
    <div class="container lesson-layout">
      <aside class="lesson-sidebar" aria-label="Lesson navigation">
        <details class="lesson-sidebar__drawer" data-lesson-nav open>
          <summary class="lesson-sidebar__summary">Lessons</summary>
          <p class="eyebrow">Lessons</p>
          <ul>
            {
              lessons.map((item) => (
                <li>
                  <a href={`/lessons/${item.slug}/`} aria-current={item.slug === lesson.slug ? 'page' : undefined}>
                    {item.number}. {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </details>
      </aside>
      <div class="lesson-content">
        <header>
          <p class="eyebrow">Lesson {lesson.number} / {lesson.eyebrow}</p>
          <h1>{lesson.title}</h1>
          <dl class="lesson-meta" aria-label="Lesson details">
            <div>
              <dt>Time</dt>
              <dd>{lessonMeta.estimatedMinutes} min</dd>
            </div>
            <div>
              <dt>Type</dt>
              <dd>{lessonMeta.type}</dd>
            </div>
            <div>
              <dt>Level</dt>
              <dd>{lessonMeta.difficulty}</dd>
            </div>
          </dl>
          <p class="lede">{lesson.summary}</p>
        </header>

        <nav class="lesson-toolbar" aria-label="Lesson quick navigation">
          <p>Lesson {currentIndex + 1} of {lessons.length}</p>
          <div>
            {previousLesson && <a href={`/lessons/${previousLesson.slug}/`}>Previous</a>}
            <a href="/lessons/">All lessons</a>
            {nextLesson && <a href={`/lessons/${nextLesson.slug}/`}>Next</a>}
          </div>
        </nav>

        <nav class="lesson-on-this-page" aria-labelledby="lesson-outline-title">
          <h2 id="lesson-outline-title">On This Page</h2>
          <ul>
            {pageSections.map((section) => (
              <li>
                <a href={section.href}>{section.label}</a>
              </li>
            ))}
          </ul>
        </nav>

        <label class="lesson-progress">
          <input type="checkbox" data-lesson-complete data-lesson-slug={lesson.slug} />
          <span data-lesson-progress-label>Mark lesson complete</span>
        </label>

        <details class="teacher-notes">
          <summary>Teacher Notes / In-Class Use</summary>
          <div class="teacher-notes__grid">
            <section>
              <h2>Demo Live</h2>
              <ul>
                {teacherNotes.demo.map((item) => <li>{item}</li>)}
              </ul>
            </section>
            <section>
              <h2>Try In Class</h2>
              <ul>
                {teacherNotes.tryInClass.map((item) => <li>{item}</li>)}
              </ul>
            </section>
            <section>
              <h2>Submit Or Check</h2>
              <ul>
                {teacherNotes.check.map((item) => <li>{item}</li>)}
              </ul>
            </section>
            <section>
              <h2>Watch For</h2>
              <ul>
                {teacherNotes.watchFor.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          </div>
        </details>

        <section id="learning-goals">
          <h2>Learning Goals</h2>
          <ul>
            {lesson.goals.map((goal) => <li>{goal}</li>)}
          </ul>
        </section>

        {
          hasInteractiveDemo && (
            <div id="interactive-demo" class="lesson-anchor-block">
              <section class="demo-guide" aria-labelledby="demo-guide-title">
                <div class="demo-guide__heading">
                  <p class="eyebrow">Interactive Demo</p>
                  <h2 id="demo-guide-title">How to use this demo.</h2>
                  <p>
                    Use the demo as a small lab. Change one thing, observe the result,
                    then connect it back to your own project.
                  </p>
                </div>
                <div class="demo-guide__grid">
                  <section>
                    <h3>What To Try</h3>
                    <ul>
                      {demoGuidance.try.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>
                  <section>
                    <h3>What Changes</h3>
                    <ul>
                      {demoGuidance.changes.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>
                  <section>
                    <h3>What To Notice</h3>
                    <ul>
                      {demoGuidance.notice.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>
                  <section>
                    <h3>Apply It</h3>
                    <ul>
                      {demoGuidance.apply.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>
                </div>
              </section>

              {lesson.slug === 'box-model-and-layout' && <BoxModelVisualizer />}

              {lesson.slug === 'file-paths-and-site-structure' && <FilePathLab />}

              {lesson.slug === 'intro-to-css' && <SelectorPlayground />}

              {lesson.slug === 'css-working-with-fonts' && <FontPairingLab />}

              {lesson.slug === 'flexbox' && <FlexboxPlayground />}

              {lesson.slug === 'responsive-web-design' && <ResponsiveLayoutVisualizer />}

              {lesson.slug === 'html-forms-building-interactive-user-interfaces' && <FormAccessibilityLab />}

              {lesson.slug === 'javascript-in-the-dom' && <DomInteractionLab />}

              {lesson.slug === 'web-accessibility' && <AccessibilityCheckLab />}

              {lesson.slug === 'css-positioning' && <PositioningLab />}

              {lesson.slug === 'transforms-filters-and-transitions' && <TransformLab />}

              {lesson.slug === 'css-transitions' && <TransitionPlayground />}

              {lesson.slug === 'css-animation' && <AnimationKeyframeLab />}

              {lesson.slug === 'gsap-web-animation' && <GsapTimelineLab />}

              {lesson.slug === 'image-optimization' && <ImageOptimizationLab />}

              {lesson.slug === 'page-types-templates-and-navigation' && <PageTemplateLab />}

              {lesson.slug === 'building-effective-site-navigation' && <NavigationPatternLab />}

              {lesson.slug === 'mastering-carousels' && <CarouselAccessibilityLab />}

              {
                demoSourceUrl && (
                  <p class="demo-source">
                    This demo uses extra JavaScript for teaching. The code sample shows the pattern to practice.
                    {' '}
                    <a href={demoSourceUrl} target="_blank" rel="noopener noreferrer">View full demo source</a>.
                  </p>
                )
              }
            </div>
          )
        }

        <div id="lesson-content" class="lesson-content-sections">
          {
            lesson.sections.map((section) => (
              <section>
                <h2>{section.title}</h2>
                {section.body?.map((paragraph) => <p set:html={renderInlineLinks(paragraph)} />)}
                {section.bullets && (
                  <ul>
                    {section.bullets.map((bullet) => <li set:html={renderInlineLinks(bullet)} />)}
                  </ul>
                )}
                {section.note && <p set:html={renderInlineLinks(section.note)} />}
                {
                  section.image && (
                    <figure class="lesson-figure">
                      <img src={section.image.src} alt={section.image.alt} loading="lazy" />
                      {section.image.caption && <figcaption>{section.image.caption}</figcaption>}
                    </figure>
                  )
                }
                {section.code && (
                  <pre><code>{section.code}</code></pre>
                )}
                {section.resources && (
                  <p class="lesson-section-resources">
                    {
                      section.resources.map((resource, index) => (
                        <>
                          {index > 0 && ' | '}
                          {typeof resource === 'string' ? (
                            <span>{resource}</span>
                          ) : (
                            <a
                              href={resource.href}
                              target={isExternalHref(resource.href) ? '_blank' : undefined}
                              rel={isExternalHref(resource.href) ? 'noopener noreferrer' : undefined}
                            >
                              {resource.label}
                            </a>
                          )}
                        </>
                      ))
                    }
                  </p>
                )}
              </section>
            ))
          }
        </div>

        <section class="lesson-checkpoint" id="checkpoint">
          <h2>Checkpoint</h2>
          <p>Before moving on, make sure these feel true.</p>
          <ul>
            {lessonCheckpoint.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        {
          supportingProjects.length > 0 && (
            <section class="lesson-supports-projects" id="supports-projects">
              <p class="eyebrow">Project Connection</p>
              <h2>This lesson supports current class projects.</h2>
              <div class="mini-card-grid">
                {
                  supportingProjects.map((project) => (
                    <a class="mini-card" href={`/projects/${project.slug}/`}>
                      <span>Project {project.number}</span>
                      <strong>{project.shortTitle}</strong>
                      <small>{project.summary}</small>
                    </a>
                  ))
                }
              </div>
            </section>
          )
        }

        {
          lesson.practice && (
            <section id="practice">
              <h2>Practice</h2>
              <ul>
                {lesson.practice.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          )
        }

        {
          lesson.resources && (
            <section id="resources">
              <h2>Resources</h2>
              <ul>
                {lesson.resources.map((resource) => (
                  <li>
                    {
                      typeof resource === 'string'
                        ? resource.startsWith('http')
                          ? (
                            <a href={resource} target="_blank" rel="noopener noreferrer">
                              {resource}
                            </a>
                          )
                          : resource
                        : (
                          <a
                            href={resource.href}
                            target={isExternalHref(resource.href) ? '_blank' : undefined}
                            rel={isExternalHref(resource.href) ? 'noopener noreferrer' : undefined}
                          >
                            {resource.label}
                          </a>
                        )
                    }
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <nav class="button-row" aria-label="Lesson pagination">
          {previousLesson && <a class="button" href={`/lessons/${previousLesson.slug}/`}>Previous</a>}
          {nextLesson && <a class="button button--primary" href={`/lessons/${nextLesson.slug}/`}>Next lesson</a>}
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<script type="module" is:inline data-astro-rerun>
  // @ts-nocheck
  const lessonNav = document.querySelector('[data-lesson-nav]');
  const lessonNavMedia = window.matchMedia('(max-width: 820px)');
  const progressCheckbox = document.querySelector('[data-lesson-complete]');
  const progressLabel = document.querySelector('[data-lesson-progress-label]');
  const progressStorageKey = 'qj-learn-completed-lessons';

  function syncLessonNav(event) {
    if (!(lessonNav instanceof HTMLDetailsElement)) return;
    lessonNav.open = !event.matches;
  }

  if (lessonNav instanceof HTMLDetailsElement) {
    syncLessonNav(lessonNavMedia);
    lessonNavMedia.addEventListener('change', syncLessonNav);
  }

  function getCompletedLessons() {
    try {
      const saved = window.localStorage.getItem(progressStorageKey);
      return new Set(saved ? JSON.parse(saved) : []);
    } catch {
      return new Set();
    }
  }

  function saveCompletedLessons(completedLessons) {
    window.localStorage.setItem(progressStorageKey, JSON.stringify([...completedLessons]));
  }

  function updateProgressLabel(isComplete) {
    if (!progressLabel) return;
    progressLabel.textContent = isComplete ? 'Lesson complete' : 'Mark lesson complete';
  }

  if (progressCheckbox instanceof HTMLInputElement) {
    const lessonSlug = progressCheckbox.dataset.lessonSlug;
    const completedLessons = getCompletedLessons();

    progressCheckbox.checked = lessonSlug ? completedLessons.has(lessonSlug) : false;
    updateProgressLabel(progressCheckbox.checked);

    progressCheckbox.addEventListener('change', () => {
      const nextCompletedLessons = getCompletedLessons();

      if (lessonSlug && progressCheckbox.checked) {
        nextCompletedLessons.add(lessonSlug);
      } else if (lessonSlug) {
        nextCompletedLessons.delete(lessonSlug);
      }

      saveCompletedLessons(nextCompletedLessons);
      updateProgressLabel(progressCheckbox.checked);
    });
  }
</script>
