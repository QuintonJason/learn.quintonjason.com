---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AccessibilityCheckLab from '../../components/AccessibilityCheckLab.astro';
import AnimationKeyframeLab from '../../components/AnimationKeyframeLab.astro';
import BoxModelVisualizer from '../../components/BoxModelVisualizer.astro';
import CarouselAccessibilityLab from '../../components/CarouselAccessibilityLab.astro';
import DomInteractionLab from '../../components/DomInteractionLab.astro';
import FlexboxPlayground from '../../components/FlexboxPlayground.astro';
import FormAccessibilityLab from '../../components/FormAccessibilityLab.astro';
import GsapTimelineLab from '../../components/GsapTimelineLab.astro';
import ImageOptimizationLab from '../../components/ImageOptimizationLab.astro';
import NavigationPatternLab from '../../components/NavigationPatternLab.astro';
import ResponsiveLayoutVisualizer from '../../components/ResponsiveLayoutVisualizer.astro';
import SelectorPlayground from '../../components/SelectorPlayground.astro';
import TransitionPlayground from '../../components/TransitionPlayground.astro';
import { getDemoSourceUrl, getLessonMeta } from '../../data/lessonMeta';
import { lessons } from '../../data/lessons';

export function getStaticPaths() {
  return lessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const currentIndex = lessons.findIndex((item) => item.slug === lesson.slug);
const previousLesson = lessons[currentIndex - 1];
const nextLesson = lessons[currentIndex + 1];
const demoSourceUrl = getDemoSourceUrl(lesson);
const lessonMeta = getLessonMeta(lesson, currentIndex);
---

<BaseLayout title={`${lesson.title} | Learn Web Design With Quinton Jason`}>
  <article class="lesson-page">
    <div class="container lesson-layout">
      <aside class="lesson-sidebar" aria-label="Lesson navigation">
        <p class="eyebrow">Lessons</p>
        <ul>
          {
            lessons.map((item) => (
              <li>
                <a href={`/lessons/${item.slug}/`} aria-current={item.slug === lesson.slug ? 'page' : undefined}>
                  {item.number}. {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </aside>
      <div class="lesson-content">
        <header>
          <p class="eyebrow">Lesson {lesson.number} / {lesson.eyebrow}</p>
          <h1>{lesson.title}</h1>
          <dl class="lesson-meta" aria-label="Lesson details">
            <div>
              <dt>Time</dt>
              <dd>{lessonMeta.estimatedMinutes} min</dd>
            </div>
            <div>
              <dt>Type</dt>
              <dd>{lessonMeta.type}</dd>
            </div>
            <div>
              <dt>Level</dt>
              <dd>{lessonMeta.difficulty}</dd>
            </div>
          </dl>
          <p class="lede">{lesson.summary}</p>
        </header>

        <nav class="lesson-toolbar" aria-label="Lesson quick navigation">
          <p>Lesson {currentIndex + 1} of {lessons.length}</p>
          <div>
            {previousLesson && <a href={`/lessons/${previousLesson.slug}/`}>Previous</a>}
            <a href="/lessons/">All lessons</a>
            {nextLesson && <a href={`/lessons/${nextLesson.slug}/`}>Next</a>}
          </div>
        </nav>

        <label class="lesson-progress">
          <input type="checkbox" data-lesson-complete data-lesson-slug={lesson.slug} />
          <span data-lesson-progress-label>Mark lesson complete</span>
        </label>

        <section>
          <h2>Learning Goals</h2>
          <ul>
            {lesson.goals.map((goal) => <li>{goal}</li>)}
          </ul>
        </section>

        {
          lesson.slug === 'box-model-and-layout' && <BoxModelVisualizer />
        }

        {
          lesson.slug === 'intro-to-css' && <SelectorPlayground />
        }

        {
          lesson.slug === 'flexbox' && <FlexboxPlayground />
        }

        {
          lesson.slug === 'responsive-web-design' && <ResponsiveLayoutVisualizer />
        }

        {
          lesson.slug === 'html-forms-building-interactive-user-interfaces' && <FormAccessibilityLab />
        }

        {
          lesson.slug === 'javascript-in-the-dom' && <DomInteractionLab />
        }

        {
          lesson.slug === 'web-accessibility' && <AccessibilityCheckLab />
        }

        {
          lesson.slug === 'css-transitions' && <TransitionPlayground />
        }

        {
          lesson.slug === 'css-animation' && <AnimationKeyframeLab />
        }

        {
          lesson.slug === 'gsap-web-animation' && <GsapTimelineLab />
        }

        {
          lesson.slug === 'image-optimization' && <ImageOptimizationLab />
        }

        {
          lesson.slug === 'building-effective-site-navigation' && <NavigationPatternLab />
        }

        {
          lesson.slug === 'mastering-carousels' && <CarouselAccessibilityLab />
        }

        {
          demoSourceUrl && (
            <p class="demo-source">
              This demo uses extra JavaScript for teaching. The code sample shows the pattern to practice.
              {' '}
              <a href={demoSourceUrl} target="_blank" rel="noopener noreferrer">View full demo source (opens in a new tab)</a>.
            </p>
          )
        }

        {
          lesson.sections.map((section) => (
            <section>
              <h2>{section.title}</h2>
              {section.body?.map((paragraph) => <p>{paragraph}</p>)}
              {section.bullets && (
                <ul>
                  {section.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              )}
              {section.note && <p>{section.note}</p>}
              {section.code && (
                <pre><code>{section.code}</code></pre>
              )}
              {section.resources && (
                <p class="lesson-section-resources">
                  {
                    section.resources.map((resource, index) => (
                      <>
                        {index > 0 && ' | '}
                        {typeof resource === 'string' ? (
                          <span>{resource}</span>
                        ) : (
                          <a href={resource.href}>{resource.label}</a>
                        )}
                      </>
                    ))
                  }
                </p>
              )}
            </section>
          ))
        }

        {
          lesson.practice && (
            <section>
              <h2>Practice</h2>
              <ul>
                {lesson.practice.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          )
        }

        {
          lesson.resources && (
            <section>
              <h2>Resources</h2>
              <ul>
                {lesson.resources.map((resource) => (
                  <li>
                    {
                      typeof resource === 'string'
                        ? resource.startsWith('http')
                          ? <a href={resource}>{resource}</a>
                          : resource
                        : <a href={resource.href}>{resource.label}</a>
                    }
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <nav class="button-row" aria-label="Lesson pagination">
          {previousLesson && <a class="button" href={`/lessons/${previousLesson.slug}/`}>Previous</a>}
          {nextLesson && <a class="button button--primary" href={`/lessons/${nextLesson.slug}/`}>Next lesson</a>}
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const progressCheckbox = document.querySelector('[data-lesson-complete]');
  const progressLabel = document.querySelector('[data-lesson-progress-label]');
  const progressStorageKey = 'qj-learn-completed-lessons';

  function getCompletedLessons() {
    try {
      const saved = window.localStorage.getItem(progressStorageKey);
      return new Set(saved ? JSON.parse(saved) : []);
    } catch {
      return new Set();
    }
  }

  function saveCompletedLessons(completedLessons) {
    window.localStorage.setItem(progressStorageKey, JSON.stringify([...completedLessons]));
  }

  function updateProgressLabel(isComplete) {
    if (!progressLabel) return;
    progressLabel.textContent = isComplete ? 'Lesson complete' : 'Mark lesson complete';
  }

  if (progressCheckbox instanceof HTMLInputElement) {
    const lessonSlug = progressCheckbox.dataset.lessonSlug;
    const completedLessons = getCompletedLessons();

    progressCheckbox.checked = lessonSlug ? completedLessons.has(lessonSlug) : false;
    updateProgressLabel(progressCheckbox.checked);

    progressCheckbox.addEventListener('change', () => {
      const nextCompletedLessons = getCompletedLessons();

      if (lessonSlug && progressCheckbox.checked) {
        nextCompletedLessons.add(lessonSlug);
      } else if (lessonSlug) {
        nextCompletedLessons.delete(lessonSlug);
      }

      saveCompletedLessons(nextCompletedLessons);
      updateProgressLabel(progressCheckbox.checked);
    });
  }
</script>
