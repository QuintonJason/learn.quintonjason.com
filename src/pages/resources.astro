---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources | Learn Web Design With Quinton Jason">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Resources</p>
        <h1>Class references.</h1>
        <p class="lede">
          A living collection of the tools, links, and references used across
          ART 3020.
        </p>
      </div>
      <div class="resource-grid">
        <article class="resource-card">
          <h2>Setup</h2>
          <p>GitHub, GitHub Desktop, Visual Studio Code, class demo repos, and GitHub Pages.</p>
        </article>
        <article class="resource-card">
          <h2>HTML and CSS</h2>
          <p>Document structure, file paths, selectors, text styling, box model, flexbox, and grid.</p>
        </article>
        <article class="resource-card">
          <h2>Interaction and Media</h2>
          <p>JavaScript, CSS motion, GSAP, responsive images, lazy loading, navigation, and carousels.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
